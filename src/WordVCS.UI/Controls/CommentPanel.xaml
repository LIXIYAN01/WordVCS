<UserControl x:Class="WordVCS.UI.Controls.CommentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WordVCS.UI.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="15,10,15,6">
            <StackPanel>
                <TextBlock Text="勾选本次解决的批注:" FontSize="12"
                           Foreground="#495057" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="全选" Click="OnSelectAll" Style="{StaticResource SmallButton}"
                            Margin="0,0,5,0" />
                    <Button Content="取消全选" Click="OnDeselectAll"
                            Style="{StaticResource SmallButton}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,0,15,8">
            <TextBlock Text="筛选:" FontSize="11" Foreground="#6C757D"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox SelectedIndex="0" Width="100" Height="24" FontSize="11"
                      SelectionChanged="OnFilterChanged">
                <ComboBoxItem>全部</ComboBoxItem>
                <ComboBoxItem>未处理</ComboBoxItem>
                <ComboBoxItem>已处理</ComboBoxItem>
                <ComboBoxItem>已忽略</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <!-- Comment list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ActiveComments}"
                          Margin="15,0,15,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="6"
                                BorderThickness="1" BorderBrush="#E9ECEF"
                                Margin="0,0,0,10" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Checkbox -->
                                <CheckBox Grid.Row="0" Grid.Column="0"
                                          IsChecked="{Binding IsChecked}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0" />

                                <!-- Author + time -->
                                <StackPanel Grid.Row="0" Grid.Column="1"
                                            Orientation="Horizontal">
                                    <TextBlock Text="{Binding Author}"
                                               FontWeight="Bold" FontSize="12"
                                               Foreground="#212529" />
                                    <TextBlock Text="{Binding CreatedDateString}"
                                               FontSize="11" Foreground="#6C757D"
                                               Margin="8,1,0,0" />
                                    <!-- Status badge -->
                                    <Border CornerRadius="3"
                                            Background="#E8F0FE"
                                            Padding="4,2" Margin="10,0,0,0"
                                            Visibility="{Binding IsAddressed,
                                                Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding StatusDisplay}"
                                                   FontSize="10" Foreground="#1A73E8" />
                                    </Border>
                                </StackPanel>

                                <!-- Comment content -->
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Content}"
                                           FontSize="12" Foreground="#495057"
                                           Margin="0,6,0,6" TextWrapping="Wrap" />

                                <!-- Selected text context -->
                                <Border Grid.Row="2" Grid.Column="1"
                                        Background="#F8F9FA"
                                        BorderThickness="3,0,0,0"
                                        BorderBrush="#CED4DA"
                                        Padding="8,4" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding SelectedText}"
                                               FontSize="11" Foreground="#6C757D"
                                               TextWrapping="Wrap"
                                               FontStyle="Italic" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
