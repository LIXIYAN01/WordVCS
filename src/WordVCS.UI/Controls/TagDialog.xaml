<Window x:Class="WordVCS.UI.Controls.TagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="创建标签" Width="400" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8F9FA">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔖 创建标签" FontSize="18"
                   FontWeight="Bold" Foreground="#212529" Margin="0,0,0,15" />

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="标签名称" FontSize="12" Foreground="#495057"
                       FontWeight="SemiBold" Margin="0,0,0,5" />
            <TextBox x:Name="TagNameBox" Height="30" FontSize="12"
                     Padding="8,5" Text="v" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="关联版本" FontSize="12" Foreground="#495057"
                       FontWeight="SemiBold" Margin="0,0,0,5" />
            <TextBlock x:Name="CommitShaText" FontSize="12" Foreground="#6C757D"
                       FontFamily="Consolas" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="标签说明 (可选)" FontSize="12" Foreground="#495057"
                       FontWeight="SemiBold" Margin="0,0,0,5" />
            <TextBox x:Name="TagMessageBox" Height="60" FontSize="12"
                     Padding="8,5" AcceptsReturn="True"
                     TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock Grid.Row="4" FontSize="11" Foreground="#6C757D"
                   TextWrapping="Wrap">
            示例: v1-sent (第一轮送审), feedback/r2-received (收到第二轮反馈)
        </TextBlock>

        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" Width="80" Height="32"
                    Background="#E9ECEF" Foreground="#495057"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="OnCancel" Margin="0,0,10,0" />
            <Button Content="创建标签" Style="{StaticResource ModernButton}"
                    Width="90" Click="OnCreate" />
        </StackPanel>
    </Grid>
</Window>
