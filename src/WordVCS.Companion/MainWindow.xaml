<Window x:Class="WordVCS.Companion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WordVCS - Paper Version Control" Height="750" Width="380"
        MinWidth="340" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Closing="OnClosing"
        Background="#F8F9FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E9ECEF"
                BorderThickness="0,0,0,1" Padding="15,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TxtTitle" Text="WordVCS" FontSize="15"
                               FontWeight="Bold" Foreground="#212529"/>
                    <Border CornerRadius="4" Background="#E8F0FE"
                            Margin="10,0,0,0" Padding="6,2">
                        <TextBlock Text="Paper VCS" FontSize="11"
                                   Foreground="#1A73E8" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="TxtStatus" Text="Connecting..."
                           FontSize="11" Foreground="#6C757D" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Task Pane -->
        <ContentControl Grid.Row="1" x:Name="TaskPaneHost"/>

        <!-- Bottom -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E9ECEF"
                BorderThickness="0,1,0,0" Padding="15,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="[Refresh]" Click="OnRefresh" Padding="10,5"
                        Margin="0,0,6,0" Background="#E8F0FE" Foreground="#0D6EFD"
                        BorderThickness="0" Cursor="Hand" FontSize="11"/>
                <Button Content="[Import Feedback]" Click="OnImport" Padding="10,5"
                        Margin="0,0,6,0" Background="#E8F0FE" Foreground="#0D6EFD"
                        BorderThickness="0" Cursor="Hand" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
