<Window x:Class="WordVCS.AddIn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WordVCS - 论文版本控制" Height="750" Width="390"
        MinWidth="340" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="True"
        Closing="OnWindowClosing"
        Loaded="OnWindowLoaded"
        Background="#F8F9FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E9ECEF" BorderThickness="0,0,0,1"
                Padding="15,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TxtTitle" Text="WordVCS"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#212529" VerticalAlignment="Center" />
                    <Border CornerRadius="4" Background="#E8F0FE"
                            Margin="10,0,0,0" Padding="6,2">
                        <TextBlock Text="论文版本控制" FontSize="11"
                                   Foreground="#1A73E8" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <TextBlock x:Name="TxtDocStatus" Text="正在连接 Word..."
                           FontSize="11" Foreground="#6C757D" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- Content Host for WPF TaskPane -->
        <ContentControl Grid.Row="1" x:Name="TaskPaneHost" />

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E9ECEF" BorderThickness="0,1,0,0"
                Padding="15,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="↻ 刷新" Click="OnRefreshClick"
                        Padding="10,5" Margin="0,0,6,0"
                        Background="#E8F0FE" Foreground="#0D6EFD"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="11" FontWeight="SemiBold" />
                <Button Content="📥 导入反馈" Click="OnImportFeedbackClick"
                        Padding="10,5" Margin="0,0,6,0"
                        Background="#E8F0FE" Foreground="#0D6EFD"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="11" FontWeight="SemiBold" />
                <Button Content="⚙ 设置" Click="OnSettingsClick"
                        Padding="10,5"
                        Background="#E8F0FE" Foreground="#0D6EFD"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="11" FontWeight="SemiBold" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
